# Nilai public berikut aman digunakan oleh browser, tetapi tetap harus berasal
# dari project Supabase yang sesuai dengan environment deployment.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Hanya untuk proses server tepercaya seperti pembuatan akun oleh supervisor,
# worker retensi file, impor, dan backup. Jangan pernah memakai nilai ini pada
# Client Component atau variabel NEXT_PUBLIC_*.
SUPABASE_SECRET_KEY=your_secret_key
